{
  "name": "reeyan-sso",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsc -p tsconfig.server.json",
    "build:client": "vite build",
    "dev:client": "vite",
    "start": "node dist/server/index.js",
    "migrate": "npx @better-auth/cli migrate --yes --config dist/server/auth.js"
  },
  "dependencies": {
    "better-auth": "^1.5.0",
    "@better-auth/oauth-provider": "^1.5.0",
    "hono": "^4.6.0",
    "@hono/node-server": "^1.13.0",
    "pg": "^8.13.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "vite": "^6.4.2"
  }
}
